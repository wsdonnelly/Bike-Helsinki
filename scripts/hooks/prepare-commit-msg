#!/bin/sh
COMMIT_FILE="$1"
COMMIT_SOURCE="$2"

# Only run for normal commits (not merges, amends, rebases, etc.)
if [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

BRANCH=$(git branch --show-current)

case "$BRANCH" in
  master|main|"") exit 0 ;;
esac

# Strip the type prefix: feature/foo -> foo, fix/bar -> bar
FEATURE=$(echo "$BRANCH" | sed 's|^[^/]*/||')

sed -i.bak "1s|^|[$FEATURE] |" "$COMMIT_FILE"
rm -f "${COMMIT_FILE}.bak"
