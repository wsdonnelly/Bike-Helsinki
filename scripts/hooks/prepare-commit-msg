#!/bin/sh
COMMIT_FILE="$1"
COMMIT_SOURCE="$2"

# Only run for normal commits (not merges, amends, rebases, etc.)
if [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

BRANCH=$(git branch --show-current)

case "$BRANCH" in
  master|main|"") exit 0 ;;
esac

sed -i.bak "1s|^|[$BRANCH] |" "$COMMIT_FILE"
rm -f "${COMMIT_FILE}.bak"
